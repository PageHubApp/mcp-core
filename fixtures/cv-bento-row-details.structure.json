      "background": "bg-(--muted)",
      "color": "text-(--foreground)"
    },
    "mobile": {
      "width": "w-full",
      "py": "py-12",
      "px": "px-6"
    },
    "desktop": {
      "py": "py-16",
      "px": "px-8"
    },
    "custom": {
      "displayName": "CV bento — highlight and status row"
    }
  },
