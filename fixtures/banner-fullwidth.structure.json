{
  "type": "Container",
  "props": {
    "canDelete": true,
    "canEditName": true,
    "className": [
      "w-[100vw]",
      "max-w-[100vw]",
      "ml-[calc(50%-50vw)]",
      "box-border"
    ],
    "root": {
      "background": "bg-(--accent)",
      "color": "text-(--accent-foreground)"
    },
    "mobile": {
      "display": "flex",
      "flexDirection": "flex-row",
      "gap": "gap-3",
      "alignItems": "items-center",
      "justifyContent": "justify-center",
      "py": "py-3",
      "px": "px-6"
    },
    "desktop": {},
    "custom": {
      "displayName": "Banner"
    }
  },
  "children": [
    {
      "type": "Text",
      "props": {
        "text": "We just launched our new feature!",
        "tagName": "p",
        "root": {
          "fontSize": "text-sm",
          "fontWeight": "font-medium"
        },
        "mobile": {},
        "desktop": {},
        "custom": {
          "displayName": "Text"
        }
      }
    },
    {
      "type": "Button",
      "props": {
        "text": "Learn more",
        "url": "#",
        "root": {
          "background": "bg-transparent",
          "color": "text-(--accent-foreground)",
          "fontSize": "text-sm",
          "fontWeight": "font-bold"
        },
        "mobile": {
          "px": "px-0",
          "py": "py-0"
        },
        "desktop": {},
        "custom": {
          "displayName": "Link"
        }
      }
    }
  ]
}
