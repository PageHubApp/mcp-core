{
  "type": "Container",
  "props": {
    "canDelete": true,
    "canEditName": true,
    "type": "section",
    "root": {
      "background": "bg-(--background)",
      "color": "text-(--foreground)"
    },
    "mobile": {
      "display": "flex",
      "flexDirection": "flex-col",
      "alignItems": "items-center",
      "textAlign": "text-center",
      "width": "w-full",
      "py": "py-16",
      "px": "px-6"
    },
    "desktop": {
      "py": "py-24",
      "px": "px-8"
    },
    "custom": {
      "displayName": "Social Proof Large Metric"
    }
  },
  "children": [
    {
      "type": "Container",
      "props": {
        "canDelete": true,
        "canEditName": true,
        "mobile": {
          "display": "flex",
          "flexDirection": "flex-col",
          "alignItems": "items-center",
          "gap": "gap-6",
          "width": "w-full",
          "maxWidth": "max-w-4xl",
          "mx": "mx-auto"
        },
        "custom": { "displayName": "Inner" }
      },
      "children": [
        {
          "type": "Text",
          "props": {
            "text": "100M+",
            "tagName": "p",
            "root": {
              "fontWeight": "font-black",
              "fontFamily": "var(--heading-font-family)",
              "lineHeight": "leading-none",
              "color": "text-(--primary)"
            },
            "mobile": { "fontSize": "text-7xl" },
            "desktop": { "fontSize": "text-9xl" },
            "custom": { "displayName": "Large Value" }
          }
        },
        {
          "type": "Text",
          "props": {
            "text": "Monthly visits across businesses powered by PageHub",
            "tagName": "h2",
            "root": {
              "fontWeight": "font-bold",
              "fontFamily": "var(--heading-font-family)",
              "lineHeight": "leading-tight"
            },
            "mobile": { "fontSize": "text-2xl", "maxWidth": "max-w-xl" },
            "desktop": { "fontSize": "text-4xl" },
            "custom": { "displayName": "Headline" }
          }
        },
        {
          "type": "Text",
          "props": {
            "text": "PageHub provides the infrastructure for high-traffic sites to thrive, from startup landing pages to enterprise marketing portals. Our edge network ensures your visitors always have a fast, reliable experience.",
            "tagName": "p",
            "root": {
              "color": "text-(--muted-foreground)",
              "lineHeight": "leading-relaxed"
            },
            "mobile": { "fontSize": "text-lg" },
            "custom": { "displayName": "Subhead" }
          }
        },
        {
          "type": "Button",
          "props": {
            "text": "See case studies",
            "url": "#",
            "root": {
              "background": "bg-(--primary)",
              "color": "text-(--primary-foreground)",
              "radius": "rounded-(--radius)"
            },
            "mobile": {
              "py": "py-3",
              "px": "px-8",
              "fontSize": "text-sm",
              "fontWeight": "font-medium",
              "mt": "mt-4"
            },
            "custom": { "displayName": "CTA Button" }
          }
        }
      ]
    }
  ]
}
