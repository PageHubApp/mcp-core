{
  "type": "Container",
  "props": {
    "type": "section",
    "canDelete": true,
    "canEditName": true,
    "custom": {
      "displayName": "FAQ card grid"
    },
    "className": "bg-(--background) text-(--foreground) flex flex-col w-full py-16 px-6 gap-12 md:py-24 md:px-8 md:gap-16"
  },
  "children": [
    {
      "type": "Container",
      "props": {
        "custom": {
          "displayName": "Header"
        },
        "className": "flex flex-col w-full max-w-(--content-width) mx-auto items-center text-center gap-4"
      },
      "children": [
        {
          "type": "Text",
          "props": {
            "text": "Common Questions",
            "tagName": "p",
            "custom": {
              "displayName": "Eyebrow"
            },
            "className": "text-(--primary) text-sm font-bold tracking-widest"
          }
        },
        {
          "type": "Text",
          "props": {
            "text": "Help at every step.",
            "tagName": "h2",
            "custom": {
              "displayName": "Heading"
            },
            "className": "font-bold leading-tight text-3xl md:text-5xl font-(--heading-font-family)"
          }
        }
      ]
    },
    {
      "type": "Container",
      "props": {
        "custom": {
          "displayName": "Grid"
        },
        "className": "grid grid-cols-1 gap-6 w-full max-w-(--content-width) mx-auto md:grid-cols-3"
      },
      "children": [
        {
          "type": "Container",
          "props": {
            "custom": {
              "displayName": "FAQ Card"
            },
            "className": "bg-(--card) rounded-(--card-radius) shadow-sm flex flex-col p-8 gap-4"
          },
          "children": [
            {
              "type": "Text",
              "props": {
                "text": "Is there a free trial?",
                "tagName": "h3",
                "custom": {
                  "displayName": "Question"
                },
                "className": "font-bold text-lg"
              }
            },
            {
              "type": "Text",
              "props": {
                "text": "Yes, every PageHub account starts with a 14-day Pro trial. No credit card required to explore our core features.",
                "tagName": "p",
                "custom": {
                  "displayName": "Answer"
                },
                "className": "text-(--muted-foreground) text-sm leading-relaxed"
              }
            }
          ]
        },
        {
          "type": "Container",
          "props": {
            "custom": {
              "displayName": "FAQ Card"
            },
            "className": "bg-(--card) rounded-(--card-radius) shadow-sm flex flex-col p-8 gap-4"
          },
          "children": [
            {
              "type": "Text",
              "props": {
                "text": "Can I cancel anytime?",
                "tagName": "h3",
                "custom": {
                  "displayName": "Question"
                },
                "className": "font-bold text-lg"
              }
            },
            {
              "type": "Text",
              "props": {
                "text": "Absolutely. PageHub subscriptions are monthly or annual. If you cancel, you'll retain access until the end of your billing cycle.",
                "tagName": "p",
                "custom": {
                  "displayName": "Answer"
                },
                "className": "text-(--muted-foreground) text-sm leading-relaxed"
              }
            }
          ]
        },
        {
          "type": "Container",
          "props": {
            "custom": {
              "displayName": "FAQ Card"
            },
            "className": "bg-(--card) rounded-(--card-radius) shadow-sm flex flex-col p-8 gap-4"
          },
          "children": [
            {
              "type": "Text",
              "props": {
                "text": "How do domains work?",
                "tagName": "h3",
                "custom": {
                  "displayName": "Question"
                },
                "className": "font-bold text-lg"
              }
            },
            {
              "type": "Text",
              "props": {
                "text": "Connect your own domain with a single CNAME record. SSL certificates are auto-provisioned and managed by us for free.",
                "tagName": "p",
                "custom": {
                  "displayName": "Answer"
                },
                "className": "text-(--muted-foreground) text-sm leading-relaxed"
              }
            }
          ]
        }
      ]
    }
  ]
}
