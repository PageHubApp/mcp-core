{
  "type": "Container",
  "props": {
    "type": "section",
    "canDelete": true,
    "canEditName": true,
    "custom": {
      "displayName": "FAQ list center"
    },
    "className": "bg-(--muted) text-(--foreground) flex flex-col w-full py-(--space-lg) px-(--container-padding-x) gap-(--space-md)"
  },
  "children": [
    {
      "type": "Container",
      "props": {
        "custom": {
          "displayName": "Header"
        },
        "className": "flex flex-col w-full max-w-2xl mx-auto items-center text-center gap-(--space-sm)"
      },
      "children": [
        {
          "type": "Text",
          "props": {
            "text": "Have queries?",
            "tagName": "h2",
            "custom": {
              "displayName": "Heading"
            },
            "className": "font-bold leading-tight text-2xl md:text-4xl font-(--heading-font-family)"
          }
        }
      ]
    },
    {
      "type": "Container",
      "props": {
        "custom": {
          "displayName": "Questions List"
        },
        "className": "flex flex-col w-full max-w-2xl mx-auto"
      },
      "children": [
        {
          "type": "Container",
          "props": {
            "custom": {
              "displayName": "FAQ Row"
            },
            "className": "border-b border-(--border) py-(--space-md) flex flex-col gap-(--space-xs)"
          },
          "children": [
            {
              "type": "Text",
              "props": {
                "text": "How secure is my data?",
                "tagName": "h3",
                "custom": {
                  "displayName": "Question"
                },
                "className": "font-bold text-base"
              }
            },
            {
              "type": "Text",
              "props": {
                "text": "Every site on PageHub is protected by enterprise-grade encryption and automated security patches.",
                "tagName": "p",
                "custom": {
                  "displayName": "Answer"
                },
                "className": "text-(--muted-foreground) text-sm leading-relaxed"
              }
            }
          ]
        },
        {
          "type": "Container",
          "props": {
            "custom": {
              "displayName": "FAQ Row"
            },
            "className": "border-b border-(--border) py-(--space-md) flex flex-col gap-(--space-xs)"
          },
          "children": [
            {
              "type": "Text",
              "props": {
                "text": "What support is included?",
                "tagName": "h3",
                "custom": {
                  "displayName": "Question"
                },
                "className": "font-bold text-base"
              }
            },
            {
              "type": "Text",
              "props": {
                "text": "All accounts include email support. Pro and Agency plans get access to priority chat and scheduled calls.",
                "tagName": "p",
                "custom": {
                  "displayName": "Answer"
                },
                "className": "text-(--muted-foreground) text-sm leading-relaxed"
              }
            }
          ]
        },
        {
          "type": "Container",
          "props": {
            "custom": {
              "displayName": "FAQ Row"
            },
            "className": "py-(--space-md) flex flex-col gap-(--space-xs)"
          },
          "children": [
            {
              "type": "Text",
              "props": {
                "text": "Which payment methods?",
                "tagName": "h3",
                "custom": {
                  "displayName": "Question"
                },
                "className": "font-bold text-base"
              }
            },
            {
              "type": "Text",
              "props": {
                "text": "We accept all major credit cards and PayPal. Enterprise users can also pay via bank transfer/wire.",
                "tagName": "p",
                "custom": {
                  "displayName": "Answer"
                },
                "className": "text-(--muted-foreground) text-sm leading-relaxed"
              }
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "props": {
        "custom": {
          "displayName": "Footer"
        },
        "className": "flex flex-col w-full max-w-2xl mx-auto items-center pt-8"
      },
      "children": [
        {
          "type": "Button",
          "props": {
            "text": "More in Help Center",
            "url": "/help",
            "custom": {
              "displayName": "Help Button"
            },
            "className": "bg-(--primary) text-(--primary-foreground) rounded-(--radius) px-(--container-padding-x) py-(--space-xs)"
          }
        }
      ]
    }
  ]
}
