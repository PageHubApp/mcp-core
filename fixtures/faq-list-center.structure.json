{
  "type": "Container",
  "props": {
    "type": "section",
    "canDelete": true,
    "canEditName": true,
    "root": {
      "background": "bg-(--muted)",
      "color": "text-(--foreground)"
    },
    "mobile": {
      "display": "flex",
      "flexDirection": "flex-col",
      "width": "w-full",
      "py": "py-16",
      "px": "px-6",
      "gap": "gap-10"
    },
    "desktop": {
      "py": "py-24",
      "px": "px-8",
      "gap": "gap-14"
    },
    "custom": {
      "displayName": "FAQ list center"
    }
  },
  "children": [
    {
      "type": "Container",
      "props": {
        "mobile": {
          "display": "flex",
          "flexDirection": "flex-col",
          "width": "w-full",
          "maxWidth": "max-w-2xl",
          "mx": "mx-auto",
          "alignItems": "items-center",
          "textAlign": "text-center",
          "gap": "gap-4"
        },
        "custom": { "displayName": "Header" }
      },
      "children": [
        {
          "type": "Text",
          "props": {
            "text": "Have queries?",
            "tagName": "h2",
            "root": {
              "fontWeight": "font-bold",
              "fontFamily": "var(--heading-font-family)",
              "lineHeight": "leading-tight"
            },
            "mobile": { "fontSize": "text-2xl" },
            "desktop": { "fontSize": "text-4xl" },
            "custom": { "displayName": "Heading" }
          }
        }
      ]
    },
    {
      "type": "Container",
      "props": {
        "mobile": {
          "display": "flex",
          "flexDirection": "flex-col",
          "width": "w-full",
          "maxWidth": "max-w-2xl",
          "mx": "mx-auto"
        },
        "custom": { "displayName": "Questions List" }
      },
      "children": [
        {
          "type": "Container",
          "props": {
            "root": { "border": "border-b", "borderColor": "border-(--border)" },
            "mobile": { "py": "py-6", "display": "flex", "flexDirection": "flex-col", "gap": "gap-2" },
            "custom": { "displayName": "FAQ Row" }
          },
          "children": [
            {
              "type": "Text",
              "props": {
                "text": "How secure is my data?",
                "tagName": "h3",
                "root": { "fontWeight": "font-bold", "fontSize": "text-base" },
                "custom": { "displayName": "Question" }
              }
            },
            {
              "type": "Text",
              "props": {
                "text": "Every site on PageHub is protected by enterprise-grade encryption and automated security patches.",
                "tagName": "p",
                "root": { "color": "text-(--muted-foreground)", "fontSize": "text-sm", "lineHeight": "leading-relaxed" },
                "custom": { "displayName": "Answer" }
              }
            }
          ]
        },
        {
          "type": "Container",
          "props": {
            "root": { "border": "border-b", "borderColor": "border-(--border)" },
            "mobile": { "py": "py-6", "display": "flex", "flexDirection": "flex-col", "gap": "gap-2" },
            "custom": { "displayName": "FAQ Row" }
          },
          "children": [
            {
              "type": "Text",
              "props": {
                "text": "What support is included?",
                "tagName": "h3",
                "root": { "fontWeight": "font-bold", "fontSize": "text-base" },
                "custom": { "displayName": "Question" }
              }
            },
            {
              "type": "Text",
              "props": {
                "text": "All accounts include email support. Pro and Agency plans get access to priority chat and scheduled calls.",
                "tagName": "p",
                "root": { "color": "text-(--muted-foreground)", "fontSize": "text-sm", "lineHeight": "leading-relaxed" },
                "custom": { "displayName": "Answer" }
              }
            }
          ]
        },
        {
          "type": "Container",
          "props": {
            "mobile": { "py": "py-6", "display": "flex", "flexDirection": "flex-col", "gap": "gap-2" },
            "custom": { "displayName": "FAQ Row" }
          },
          "children": [
            {
              "type": "Text",
              "props": {
                "text": "Which payment methods?",
                "tagName": "h3",
                "root": { "fontWeight": "font-bold", "fontSize": "text-base" },
                "custom": { "displayName": "Question" }
              }
            },
            {
              "type": "Text",
              "props": {
                "text": "We accept all major credit cards and PayPal. Enterprise users can also pay via bank transfer/wire.",
                "tagName": "p",
                "root": { "color": "text-(--muted-foreground)", "fontSize": "text-sm", "lineHeight": "leading-relaxed" },
                "custom": { "displayName": "Answer" }
              }
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "props": {
        "mobile": {
          "display": "flex",
          "flexDirection": "flex-col",
          "width": "w-full",
          "maxWidth": "max-w-2xl",
          "mx": "mx-auto",
          "alignItems": "items-center",
          "pt": "pt-8"
        },
        "custom": { "displayName": "Footer" }
      },
      "children": [
        {
          "type": "Button",
          "props": {
            "text": "More in Help Center",
            "url": "/help",
            "root": { "background": "bg-(--primary)", "color": "text-(--primary-foreground)", "radius": "rounded-(--radius)" },
            "mobile": { "px": "px-6", "py": "py-2" },
            "custom": { "displayName": "Help Button" }
          }
        }
      ]
    }
  ]
}
