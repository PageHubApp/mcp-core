{
  "type": "Container",
  "props": {
    "canDelete": true,
    "canEditName": true,
    "type": "section",
    "custom": {
      "displayName": "Contact Section"
    },
    "className": "bg-(--background) text-(--foreground) flex flex-col w-full py-16 px-6 md:py-24 md:px-10"
  },
  "children": [
    {
      "type": "Container",
      "props": {
        "canDelete": true,
        "canEditName": true,
        "custom": {
          "displayName": "Content"
        },
        "className": "max-w-lg w-full flex flex-col items-start gap-8 mx-auto md:mx-auto"
      },
      "children": [
        {
          "type": "Container",
          "props": {
            "canDelete": true,
            "canEditName": true,
            "custom": {
              "displayName": "Contact header"
            },
            "className": "w-full flex flex-col items-center gap-3 text-center md:gap-4"
          },
          "children": [
            {
              "type": "Text",
              "props": {
                "text": "Contact Us",
                "tagName": "h2",
                "canDelete": true,
                "canEditName": true,
                "custom": {
                  "displayName": "Title"
                },
                "className": "text-3xl font-bold leading-tight md:text-4xl font-(--heading-font-family)"
              }
            },
            {
              "type": "Text",
              "props": {
                "text": "Have a question or feedback? Need details about our plans? Let us know and we will get back to you as soon as we can.",
                "tagName": "p",
                "canDelete": true,
                "canEditName": true,
                "custom": {
                  "displayName": "Description"
                },
                "className": "text-(--muted-foreground) text-base leading-relaxed max-w-2xl"
              }
            }
          ]
        },
        {
          "type": "Form",
          "props": {
            "canDelete": true,
            "canEditName": true,
            "formName": "contact",
            "formType": "contact",
            "custom": {
              "displayName": "Contact Form"
            },
            "className": "w-full flex flex-col gap-5"
          },
          "children": [
            {
              "type": "FormElement",
              "props": {
                "type": "text",
                "name": "name",
                "label": "Name:",
                "placeholder": "Enter your name",
                "required": true,
                "autocomplete": "name",
                "root": {
                  "style": "placeholder-color: placeholder:text-(--input-placeholder-color);"
                },
                "canDelete": true,
                "canEditName": true,
                "custom": {
                  "displayName": "Name"
                },
                "className": "border border-(--input-border-width) border-solid border-(--input-border-color) rounded-(--input-border-radius) bg-(--input-bg-color) text-(--input-text-color) p-(--input-padding) w-full"
              }
            },
            {
              "type": "FormElement",
              "props": {
                "type": "email",
                "name": "email",
                "label": "Email:",
                "placeholder": "Enter your email",
                "required": true,
                "autocomplete": "email",
                "root": {
                  "style": "placeholder-color: placeholder:text-(--input-placeholder-color);"
                },
                "canDelete": true,
                "canEditName": true,
                "custom": {
                  "displayName": "Email"
                },
                "className": "border border-(--input-border-width) border-solid border-(--input-border-color) rounded-(--input-border-radius) bg-(--input-bg-color) text-(--input-text-color) p-(--input-padding) w-full"
              }
            },
            {
              "type": "FormElement",
              "props": {
                "type": "textarea",
                "name": "message",
                "label": "Message:",
                "placeholder": "Enter your message",
                "required": true,
                "rows": 6,
                "root": {
                  "style": "placeholder-color: placeholder:text-(--input-placeholder-color);"
                },
                "canDelete": true,
                "canEditName": true,
                "custom": {
                  "displayName": "Message"
                },
                "className": "border border-(--input-border-width) border-solid border-(--input-border-color) rounded-(--input-border-radius) bg-(--input-bg-color) text-(--input-text-color) p-(--input-padding) w-full min-h-[140px]"
              }
            },
            {
              "type": "Container",
              "props": {
                "canDelete": true,
                "canEditName": true,
                "custom": {
                  "displayName": "Disclaimer"
                },
                "className": "text-(--muted-foreground) w-full flex flex-row flex-wrap items-start gap-2"
              },
              "children": [
                {
                  "type": "Button",
                  "props": {
                    "text": "Form requirements",
                    "url": "#",
                    "icon": {
                      "value": "ref-google:info",
                      "only": true,
                      "size": "w-4 h-4"
                    },
                    "canDelete": true,
                    "canEditName": true,
                    "custom": {
                      "displayName": "Info Icon"
                    },
                    "className": "bg-transparent text-(--muted-foreground) p-0 py-0 px-0 w-auto min-w-0 shrink-0 flex mt-0.5"
                  }
                },
                {
                  "type": "Container",
                  "props": {
                    "canDelete": true,
                    "canEditName": true,
                    "custom": {
                      "displayName": "Disclaimer copy"
                    },
                    "className": "flex row flex-wrap items-baseline gap-x-1 flex-1 min-w-0"
                  },
                  "children": [
                    {
                      "type": "Text",
                      "props": {
                        "text": "All the fields are required. By sending the form you agree to the",
                        "tagName": "span",
                        "canDelete": true,
                        "canEditName": true,
                        "custom": {
                          "displayName": "Disclaimer lead"
                        },
                        "className": "text-sm leading-relaxed"
                      }
                    },
                    {
                      "type": "Button",
                      "props": {
                        "text": "Terms & Conditions",
                        "url": "/terms",
                        "canDelete": true,
                        "canEditName": true,
                        "custom": {
                          "displayName": "Terms link"
                        },
                        "className": "bg-transparent text-(--foreground) underline p-0 py-0 px-0 w-auto min-w-0 text-sm font-medium inline-flex"
                      }
                    },
                    {
                      "type": "Text",
                      "props": {
                        "text": "and",
                        "tagName": "span",
                        "canDelete": true,
                        "canEditName": true,
                        "custom": {
                          "displayName": "Disclaimer and"
                        },
                        "className": "text-(--muted-foreground) text-sm"
                      }
                    },
                    {
                      "type": "Button",
                      "props": {
                        "text": "Privacy Policy",
                        "url": "/privacy",
                        "canDelete": true,
                        "canEditName": true,
                        "custom": {
                          "displayName": "Privacy link"
                        },
                        "className": "bg-transparent text-(--foreground) underline p-0 py-0 px-0 w-auto min-w-0 text-sm font-medium inline-flex"
                      }
                    },
                    {
                      "type": "Text",
                      "props": {
                        "text": ".",
                        "tagName": "span",
                        "canDelete": true,
                        "canEditName": true,
                        "custom": {
                          "displayName": "Disclaimer end"
                        },
                        "className": "text-(--muted-foreground) text-sm"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "type": "Button",
              "props": {
                "type": "submit",
                "text": "SEND MESSAGE",
                "icon": {
                  "value": "ref-google:auto_awesome",
                  "position": "right",
                  "size": "w-5 h-5",
                  "gap": "gap-2"
                },
                "canDelete": true,
                "canEditName": true,
                "custom": {
                  "displayName": "Submit"
                },
                "className": "bg-(--background) text-(--foreground) border-2 border-(--foreground) rounded-(--radius) w-full py-3.5 px-6 font-bold text-sm tracking-wide text-center flex justify-center items-center"
              }
            }
          ]
        }
      ]
    }
  ]
}
