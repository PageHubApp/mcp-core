{
  "type": "Container",
  "props": {
    "canDelete": true,
    "canEditName": true,
    "type": "section",
    "custom": {
      "displayName": "Coming soon hero"
    },
    "className": "bg-(--background) text-(--foreground) flex flex-col items-center justify-center w-full min-h-screen py-12 px-6 md:py-20 md:px-16"
  },
  "children": [
    {
      "type": "Container",
      "props": {
        "canDelete": true,
        "canEditName": true,
        "custom": {
          "displayName": "Section inner"
        },
        "className": "flex flex-col items-center w-full max-w-(--content-width) mx-auto gap-10"
      },
      "children": [
        {
          "type": "Text",
          "props": {
            "canDelete": true,
            "canEditName": true,
            "text": "LAUNCHING {{year}}",
            "className": "text-(--primary) font-semibold text-sm tracking-[0.25em] uppercase font-(--heading-font-family)",
            "custom": {
              "displayName": "Eyebrow"
            }
          }
        },
        {
          "type": "Text",
          "props": {
            "canDelete": true,
            "canEditName": true,
            "text": "Something big is landing",
            "className": "text-(--foreground) font-extrabold text-5xl w-full md:text-8xl tracking-tight text-center font-(--heading-font-family)",
            "custom": {
              "displayName": "Heading"
            }
          }
        },
        {
          "type": "Text",
          "props": {
            "canDelete": true,
            "canEditName": true,
            "text": "We are polishing the next workspace drop. Leave an email if you want one ping when it opens — no promos, just the release.",
            "className": "text-(--muted-foreground) leading-relaxed text-lg w-full md:text-xl md:w-6/12 text-center font-(--body-font-family)",
            "custom": {
              "displayName": "Subheading"
            }
          }
        },
        {
          "type": "Container",
          "props": {
            "canDelete": true,
            "canEditName": true,
            "custom": {
              "displayName": "Form wrapper"
            },
            "className": "flex flex-col items-center w-full gap-4 md:w-full md:max-w-xl"
          },
          "children": [
            {
              "type": "Form",
              "props": {
                "canDelete": true,
                "canEditName": true,
                "formName": "coming-soon-notify",
                "formType": "subscribe",
                "custom": {
                  "displayName": "Email signup"
                },
                "className": "flex flex-col w-full gap-3 md:flex-row md:gap-0 md:items-stretch"
              },
              "children": [
                {
                  "type": "FormElement",
                  "props": {
                    "canDelete": true,
                    "canEditName": true,
                    "type": "email",
                    "name": "email",
                    "label": "",
                    "placeholder": "you@workspace.com",
                    "required": true,
                    "autocomplete": "email",
                    "custom": {
                      "displayName": "Email input"
                    },
                    "className": "border border-(--input-border-width) border-solid border-(--input-border-color) rounded-l-(--input-border-radius) bg-(--input-bg-color) text-(--input-text-color) p-(--input-padding) w-full md:flex-1"
                  }
                },
                {
                  "type": "Button",
                  "props": {
                    "canDelete": true,
                    "canEditName": true,
                    "type": "submit",
                    "text": "Get notified",
                    "icon": {
                      "value": "ref-google:arrow_forward",
                      "position": "right",
                      "size": "w-5 h-5",
                      "gap": "gap-2"
                    },
                    "className": "bg-(--primary) text-(--primary-foreground) rounded-r-(--radius) font-semibold w-full px-(--button-padding-x) py-3 flex items-center justify-center md:w-auto md:shrink-0 whitespace-nowrap",
                    "custom": {
                      "displayName": "Submit"
                    }
                  }
                }
              ]
            }
          ]
        },
        {
          "type": "Text",
          "props": {
            "canDelete": true,
            "canEditName": true,
            "text": "No spam. Unsubscribe from builder mail anytime.",
            "className": "text-(--muted-foreground) text-sm text-center font-(--body-font-family)",
            "custom": {
              "displayName": "Privacy note"
            }
          }
        }
      ]
    }
  ]
}
