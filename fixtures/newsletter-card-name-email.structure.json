{
  "type": "Container",
  "props": {
    "type": "section",
    "canDelete": true,
    "canEditName": true,
    "custom": {
      "displayName": "Newsletter card name email section"
    },
    "className": "bg-(--background) text-(--foreground) w-full py-16 px-6 md:py-20 md:px-8"
  },
  "children": [
    {
      "type": "Container",
      "props": {
        "canDelete": true,
        "canEditName": true,
        "custom": {
          "displayName": "Section inner"
        },
        "className": "flex w-full justify-center"
      },
      "children": [
        {
          "type": "Container",
          "props": {
            "canDelete": true,
            "canEditName": true,
            "custom": {
              "displayName": "Subscribe card"
            },
            "className": "bg-(--card) text-(--card-foreground) rounded-(--card-radius) border border-(--muted) shadow-sm flex flex-col gap-6 p-8 w-full max-w-md mx-auto text-center items-center"
          },
          "children": [
            {
              "type": "Text",
              "props": {
                "text": "The PageHub changelog, in your inbox",
                "tagName": "h2",
                "root": {
                  "style": "font-family: var(--heading-font-family);"
                },
                "custom": {
                  "displayName": "Heading"
                },
                "className": "font-bold text-(--card-foreground) leading-tight text-2xl md:text-3xl"
              }
            },
            {
              "type": "Text",
              "props": {
                "text": "Release notes, builder tips, and early access when we open new programs — usually under twice a month.",
                "tagName": "p",
                "custom": {
                  "displayName": "Subhead"
                },
                "className": "text-(--muted-foreground) text-sm leading-relaxed"
              }
            },
            {
              "type": "Form",
              "props": {
                "canDelete": true,
                "canEditName": true,
                "formName": "newsletter-card-name-email",
                "formType": "subscribe",
                "custom": {
                  "displayName": "Subscribe form"
                },
                "className": "w-full flex flex-col gap-4 text-left items-stretch"
              },
              "children": [
                {
                  "type": "FormElement",
                  "props": {
                    "type": "text",
                    "name": "name",
                    "label": "Name",
                    "placeholder": "Alex Rivera",
                    "required": false,
                    "autocomplete": "name",
                    "root": {
                      "style": "placeholder-color: placeholder:text-(--input-placeholder-color);"
                    },
                    "canDelete": true,
                    "canEditName": true,
                    "custom": {
                      "displayName": "Name"
                    },
                    "className": "border border-(--input-border-width) border-solid border-(--input-border-color) rounded-(--input-border-radius) bg-(--input-bg-color) text-(--input-text-color) p-(--input-padding) w-full"
                  }
                },
                {
                  "type": "FormElement",
                  "props": {
                    "type": "email",
                    "name": "email",
                    "label": "Work email",
                    "placeholder": "you@company.com",
                    "required": true,
                    "autocomplete": "email",
                    "root": {
                      "style": "placeholder-color: placeholder:text-(--input-placeholder-color);"
                    },
                    "canDelete": true,
                    "canEditName": true,
                    "custom": {
                      "displayName": "Email"
                    },
                    "className": "border border-(--input-border-width) border-solid border-(--input-border-color) rounded-(--input-border-radius) bg-(--input-bg-color) text-(--input-text-color) p-(--input-padding) w-full"
                  }
                },
                {
                  "type": "Button",
                  "props": {
                    "text": "Join the list",
                    "type": "submit",
                    "custom": {
                      "displayName": "Submit"
                    },
                    "className": "bg-(--primary) text-(--primary-foreground) rounded-(--radius) w-full py-3 px-6 font-semibold text-sm text-center"
                  }
                }
              ]
            },
            {
              "type": "Text",
              "props": {
                "text": "We process signups inside PageHub; unsubscribe from any message and we honor it immediately.",
                "tagName": "p",
                "custom": {
                  "displayName": "Privacy"
                },
                "className": "text-(--muted-foreground) text-xs leading-relaxed"
              }
            }
          ]
        }
      ]
    }
  ]
}
