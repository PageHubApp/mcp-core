{
  "type": "Container",
  "props": {
    "type": "section",
    "canDelete": true,
    "canEditName": true,
    "root": {
      "background": "bg-(--background)",
      "color": "text-(--foreground)"
    },
    "mobile": {
      "width": "w-full",
      "py": "py-16",
      "px": "px-6"
    },
    "desktop": {
      "py": "py-20",
      "px": "px-8"
    },
    "custom": {
      "displayName": "Newsletter card name email section"
    }
  },
  "children": [
    {
      "type": "Container",
      "props": {
        "canDelete": true,
        "canEditName": true,
        "root": {},
        "mobile": {
          "display": "flex",
          "width": "w-full",
          "justifyContent": "justify-center"
        },
        "custom": {
          "displayName": "Section inner"
        }
      },
      "children": [
        {
          "type": "Container",
          "props": {
            "canDelete": true,
            "canEditName": true,
            "root": {
              "background": "bg-(--card)",
              "color": "text-(--card-foreground)",
              "radius": "rounded-(--card-radius)",
              "border": "border",
              "borderColor": "border-(--muted)",
              "shadow": "shadow-sm"
            },
            "mobile": {
              "display": "flex",
              "flexDirection": "flex-col",
              "gap": "gap-6",
              "p": "p-8",
              "width": "w-full",
              "maxWidth": "max-w-md",
              "mx": "mx-auto",
              "textAlign": "text-center",
              "alignItems": "items-center"
            },
            "custom": {
              "displayName": "Subscribe card"
            }
          },
          "children": [
            {
              "type": "Text",
              "props": {
                "text": "The PageHub changelog, in your inbox",
                "tagName": "h2",
                "root": {
                  "fontFamily": "var(--heading-font-family)",
                  "fontWeight": "font-bold",
                  "color": "text-(--card-foreground)",
                  "lineHeight": "leading-tight"
                },
                "mobile": {
                  "fontSize": "text-2xl"
                },
                "desktop": {
                  "fontSize": "text-3xl"
                },
                "custom": {
                  "displayName": "Heading"
                }
              }
            },
            {
              "type": "Text",
              "props": {
                "text": "Release notes, builder tips, and early access when we open new programs — usually under twice a month.",
                "tagName": "p",
                "root": {
                  "color": "text-(--muted-foreground)"
                },
                "mobile": {
                  "fontSize": "text-sm",
                  "lineHeight": "leading-relaxed"
                },
                "custom": {
                  "displayName": "Subhead"
                }
              }
            },
            {
              "type": "Form",
              "props": {
                "canDelete": true,
                "canEditName": true,
                "formName": "newsletter-card-name-email",
                "formType": "subscribe",
                "root": {
                  "width": "w-full"
                },
                "mobile": {
                  "display": "flex",
                  "flexDirection": "flex-col",
                  "gap": "gap-4",
                  "width": "w-full",
                  "textAlign": "text-left",
                  "alignItems": "items-stretch"
                },
                "custom": {
                  "displayName": "Subscribe form"
                }
              },
              "children": [
                {
                  "type": "FormElement",
                  "props": {
                    "type": "text",
                    "name": "name",
                    "label": "Name",
                    "placeholder": "Alex Rivera",
                    "required": false,
                    "autocomplete": "name",
                    "root": {
                      "border": "border",
                      "borderWidth": "border-(--input-border-width)",
                      "borderStyle": "border-solid",
                      "borderColor": "border-(--input-border-color)",
                      "radius": "rounded-(--input-border-radius)",
                      "background": "bg-(--input-bg-color)",
                      "color": "text-(--input-text-color)",
                      "placeholderColor": "placeholder:text-(--input-placeholder-color)",
                      "focus": {
                        "ring": "focus:ring-(--input-focus-ring)",
                        "ringColor": "focus:ring-(--input-focus-ring-color)",
                        "outline": "focus:outline-none"
                      }
                    },
                    "mobile": {
                      "p": "p-(--input-padding)",
                      "width": "w-full"
                    },
                    "canDelete": true,
                    "canEditName": true,
                    "custom": {
                      "displayName": "Name"
                    }
                  }
                },
                {
                  "type": "FormElement",
                  "props": {
                    "type": "email",
                    "name": "email",
                    "label": "Work email",
                    "placeholder": "you@company.com",
                    "required": true,
                    "autocomplete": "email",
                    "root": {
                      "border": "border",
                      "borderWidth": "border-(--input-border-width)",
                      "borderStyle": "border-solid",
                      "borderColor": "border-(--input-border-color)",
                      "radius": "rounded-(--input-border-radius)",
                      "background": "bg-(--input-bg-color)",
                      "color": "text-(--input-text-color)",
                      "placeholderColor": "placeholder:text-(--input-placeholder-color)",
                      "focus": {
                        "ring": "focus:ring-(--input-focus-ring)",
                        "ringColor": "focus:ring-(--input-focus-ring-color)",
                        "outline": "focus:outline-none"
                      }
                    },
                    "mobile": {
                      "p": "p-(--input-padding)",
                      "width": "w-full"
                    },
                    "canDelete": true,
                    "canEditName": true,
                    "custom": {
                      "displayName": "Email"
                    }
                  }
                },
                {
                  "type": "Button",
                  "props": {
                    "text": "Join the list",
                    "type": "submit",
                    "root": {
                      "background": "bg-(--primary)",
                      "color": "text-(--primary-foreground)",
                      "radius": "rounded-(--radius)"
                    },
                    "mobile": {
                      "width": "w-full",
                      "py": "py-3",
                      "px": "px-6",
                      "fontWeight": "font-semibold",
                      "fontSize": "text-sm",
                      "textAlign": "text-center"
                    },
                    "custom": {
                      "displayName": "Submit"
                    }
                  }
                }
              ]
            },
            {
              "type": "Text",
              "props": {
                "text": "We process signups inside PageHub; unsubscribe from any message and we honor it immediately.",
                "tagName": "p",
                "root": {
                  "color": "text-(--muted-foreground)"
                },
                "mobile": {
                  "fontSize": "text-xs",
                  "lineHeight": "leading-relaxed"
                },
                "custom": {
                  "displayName": "Privacy"
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
