{
  "type": "Container",
  "props": {
    "canDelete": true,
    "canEditName": true,
    "type": "section",
    "custom": {
      "displayName": "Construction contact — map + details"
    },
    "className": "bg-(--background) text-(--foreground) flex flex-col items-center w-full py-24 px-8"
  },
  "children": [
    {
      "type": "Container",
      "props": {
        "canDelete": true,
        "canEditName": true,
        "custom": {
          "displayName": "Section inner"
        },
        "className": "flex flex-col items-center w-full max-w-(--content-width) mx-auto"
      },
      "children": [
        {
          "type": "Text",
          "props": {
            "canDelete": true,
            "canEditName": true,
            "text": "CONTACT",
            "tagName": "h3",
            "className": "text-(--foreground) text-2xl font-bold tracking-widest mb-16 inline-block border-b-4 border-(--accent) pb-2",
            "custom": {
              "displayName": "Section title"
            }
          }
        },
        {
          "type": "Container",
          "props": {
            "canDelete": true,
            "canEditName": true,
            "custom": {
              "displayName": "Contact row"
            },
            "className": "flex flex-col w-full max-w-5xl gap-16 md:flex-row md:gap-24"
          },
          "children": [
            {
              "type": "Container",
              "props": {
                "canDelete": true,
                "canEditName": true,
                "custom": {
                  "displayName": "Map + copy"
                },
                "className": "flex flex-col flex-1"
              },
              "children": [
                {
                  "type": "Container",
                  "props": {
                    "root": {
                      "style": "background: bg-(--muted) bg-cover bg-center bg-no-repeat;"
                    },
                    "backgroundImage": "https://images.unsplash.com/photo-1524661135-423995f22d0b?q=80&w=800&auto=format&fit=crop",
                    "backgroundImageType": "url",
                    "custom": {
                      "displayName": "Map visual"
                    },
                    "className": "w-full h-64 mb-12 bg-cover bg-center bg-no-repeat"
                  }
                },
                {
                  "type": "Container",
                  "props": {
                    "canDelete": true,
                    "canEditName": true,
                    "custom": {
                      "displayName": "Detail grid"
                    },
                    "className": "grid grid-cols-1 gap-8 md:grid-cols-2"
                  },
                  "children": [
                    {
                      "type": "Container",
                      "props": {
                        "className": "flex flex-col"
                      },
                      "children": [
                        {
                          "type": "Text",
                          "props": {
                            "text": "Inquiries",
                            "className": "text-(--foreground) font-bold mb-4 text-sm"
                          }
                        },
                        {
                          "type": "Text",
                          "props": {
                            "text": "For workspace questions or demos, call <span data-variable=\"company.phone\">{{company.phone}}</span> or route visitors through your published contact form.",
                            "className": "text-(--muted-foreground) text-sm leading-relaxed"
                          }
                        }
                      ]
                    },
                    {
                      "type": "Container",
                      "props": {
                        "className": "flex flex-col"
                      },
                      "children": [
                        {
                          "type": "Text",
                          "props": {
                            "text": "Head office",
                            "className": "text-(--foreground) font-bold mb-4 text-sm"
                          }
                        },
                        {
                          "type": "Text",
                          "props": {
                            "text": "<span data-variable=\"company.address\">{{company.address}}</span><br/><br/><span data-variable=\"company.email\">{{company.email}}</span><br/>Tel: <span data-variable=\"company.phone\">{{company.phone}}</span>",
                            "className": "text-(--muted-foreground) text-sm leading-relaxed"
                          }
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
