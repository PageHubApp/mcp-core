                "custom": {
                  "displayName": "Email field group"
                }
              },
              "children": [
                {
                  "type": "Button",
                  "props": {
                    "type": "button",
                    "text": " ",
                    "icon": {
                      "value": "ref-google:mail",
                      "only": true,
                      "size": "w-5 h-5",
                      "color": "text-(--muted-foreground)"
                    },
                    "className": "bg-transparent py-(--space-xs) px-(--container-padding-x) hidden lg:inline-flex lg:items-center lg:justify-center lg:shrink-0 lg:self-stretch",
                    "custom": {
                      "displayName": "Mail icon"
                    }
                  }
                },
                {
                  "type": "FormElement",
                  "props": {
                    "type": "email",
                    "name": "email",
                    "label": "",
                    "placeholder": "you@company.com",
                    "required": true,
                    "autocomplete": "email",
                    "root": {
                      "style": "placeholder-color: placeholder:text-(--input-placeholder-color);"
                    },
                    "canDelete": true,
                    "canEditName": true,
                    "custom": {
                      "displayName": "Email"
                    },
                    "className": "border-0 rounded-none bg-transparent text-(--input-text-color) py-(--space-xs) px-(--container-padding-x) w-full flex-1 min-w-0"
                  }
                },
                {
                  "type": "Button",
                  "props": {
                    "type": "submit",
                    "text": "Subscribe",
                    "className": "bg-(--primary) text-(--primary-foreground) rounded-none w-full py-(--space-xs) px-(--container-padding-x) font-semibold text-sm text-center flex justify-center items-center border-t border-(--input-border-color) lg:border-t-0 lg:border-l lg:border-(--input-border-color) lg:w-auto lg:shrink-0",
                    "custom": {
                      "displayName": "Submit"
                    }
                  }
                }
              ]
            },
            {
              "type": "Container",
              "props": {
                "canDelete": true,
                "canEditName": true,
                "custom": {
