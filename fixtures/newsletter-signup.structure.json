{
  "type": "Container",
  "props": {
    "type": "section",
    "canDelete": true,
    "canEditName": true,
    "custom": {
      "displayName": "Newsletter capture section"
    },
    "className": "bg-(--background) text-(--foreground) flex flex-col w-full max-w-none py-(--space-lg) px-(--container-padding-x)"
  },
  "children": [
    {
      "type": "Container",
      "props": {
        "canDelete": true,
        "canEditName": true,
        "custom": {
