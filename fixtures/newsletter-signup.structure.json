                    },
                    "mobile": {
                      "fontSize": "text-xs",
                      "lineHeight": "leading-relaxed"
                    },
                    "custom": {
                      "displayName": "Privacy prefix"
                    }
                  }
                },
                {
                  "type": "Button",
                  "props": {
                    "text": "Privacy policy",
                    "url": "#",
                    "root": {
                      "background": "bg-transparent",
                      "color": "text-(--primary)"
                    },
                    "mobile": {
                      "px": "px-0",
                      "py": "py-0",
                      "fontSize": "text-xs",
                      "fontWeight": "font-medium"
                    },
                    "custom": {
                      "displayName": "Privacy link"
                    }
                  }
                }
              ]
