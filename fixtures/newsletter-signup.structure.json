        "className": "flex flex-col gap-(--space-sm) w-full max-w-xl mx-auto items-stretch"
      },
      "children": [
        {
          "type": "Text",
          "props": {
            "text": "Product mail",
            "tagName": "p",
            "className": "text-(--primary) font-bold tracking-widest text-xs uppercase",
            "custom": {
              "displayName": "Eyebrow"
            }
          }
        },
        {
          "type": "Text",
          "props": {
            "text": "Ship notes without the noise",
            "tagName": "h2",
            "custom": {
              "displayName": "Heading"
            },
            "className": "font-bold leading-tight text-(--foreground) text-3xl md:text-4xl font-(--heading-font-family)"
          }
        },
        {
          "type": "Text",
          "props": {
