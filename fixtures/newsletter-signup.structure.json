                {
                  "type": "Button",
                  "props": {
                    "text": "Privacy policy",
                    "url": "#",
                    "custom": {
                      "displayName": "Privacy link"
                    },
                    "className": "bg-transparent text-(--primary) px-(--container-padding-x) py-(--space-xs) text-xs font-medium"
