                        "className": "bg-transparent text-(--muted-foreground) border-0 text-sm font-medium px-(--container-padding-x) py-(--space-xs)"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
