{
  "type": "Container",
  "props": {
    "type": "section",
    "canDelete": true,
    "canEditName": true,
    "className": "bg-(--muted) text-(--foreground) flex flex-col w-full max-w-none py-4 px-4 md:py-5 md:px-6 border-y border-(--border)",
    "custom": {
      "displayName": "Newsletter footer strip section"
    }
  },
  "children": [
    {
      "type": "Container",
      "props": {
        "canDelete": true,
        "canEditName": true,
        "custom": {
          "displayName": "Strip inner"
        },
        "className": "flex flex-col gap-4 w-full max-w-(--content-width) mx-auto items-stretch md:flex-row md:items-center md:justify-between md:gap-8"
      },
      "children": [
        {
          "type": "Container",
          "props": {
            "canDelete": true,
            "canEditName": true,
            "custom": {
              "displayName": "Copy column"
            },
            "className": "flex flex-col gap-1 w-full min-w-0 md:flex-none md:max-w-sm"
          },
          "children": [
            {
              "type": "Text",
              "props": {
                "text": "Product updates in your inbox",
                "tagName": "p",
                "custom": {
                  "displayName": "Strip headline"
                },
                "className": "font-semibold text-(--foreground) text-sm md:text-base"
              }
            },
            {
              "type": "Text",
              "props": {
                "text": "One email a month. Unsubscribe anytime; we never sell addresses.",
                "tagName": "p",
                "custom": {
                  "displayName": "Strip subline"
                },
                "className": "text-(--muted-foreground) text-xs leading-relaxed md:text-sm"
              }
            }
          ]
        },
        {
          "type": "Form",
          "props": {
            "canDelete": true,
            "canEditName": true,
            "formName": "newsletter-footer-strip",
            "formType": "subscribe",
            "custom": {
              "displayName": "Inline subscribe form"
            },
            "className": "flex flex-col w-full min-w-0 md:flex-1 md:max-w-md md:min-w-0"
          },
          "children": [
            {
              "type": "Container",
              "props": {
                "canDelete": true,
                "canEditName": true,
                "custom": {
                  "displayName": "Email + submit shell"
                },
                "className": "bg-(--background) border border-(--border) rounded-(--radius) flex flex-row items-stretch w-full overflow-hidden"
              },
              "children": [
                {
                  "type": "FormElement",
                  "props": {
                    "type": "email",
                    "name": "email",
                    "label": "",
                    "placeholder": "you@company.com",
                    "required": true,
                    "autocomplete": "email",
                    "root": {
                      "style": "placeholder-color: placeholder:text-(--input-placeholder-color);"
                    },
                    "canDelete": true,
                    "canEditName": true,
                    "custom": {
                      "displayName": "Email"
                    },
                    "className": "border-0 rounded-none bg-transparent text-(--input-text-color) px-3 py-2.5 w-full flex-1 min-w-0 text-sm"
                  }
                },
                {
                  "type": "Button",
                  "props": {
                    "text": "Subscribe",
                    "type": "submit",
                    "custom": {
                      "displayName": "Submit"
                    },
                    "className": "bg-(--primary) text-(--primary-foreground) rounded-none border-0 inline-flex items-center justify-center shrink-0 px-4 py-2.5 text-sm font-semibold border-l border-(--border)"
                  }
                }
              ]
            }
          ]
        }
