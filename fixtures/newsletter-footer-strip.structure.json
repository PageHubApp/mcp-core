{
  "type": "Container",
  "props": {
    "type": "section",
    "canDelete": true,
    "canEditName": true,
    "root": {
      "background": "bg-(--muted)",
      "color": "text-(--foreground)"
    },
    "className": ["border-y", "border-(--border)"],
    "mobile": {
      "display": "flex",
      "flexDirection": "flex-col",
      "width": "w-full",
      "maxWidth": "max-w-none",
      "py": "py-4",
      "px": "px-4"
    },
    "desktop": {
      "py": "py-5",
      "px": "px-6"
    },
    "custom": {
      "displayName": "Newsletter footer strip section"
    }
  },
  "children": [
    {
      "type": "Container",
      "props": {
        "canDelete": true,
        "canEditName": true,
        "root": {},
        "mobile": {
          "display": "flex",
          "flexDirection": "flex-col",
          "gap": "gap-4",
          "width": "w-full",
          "maxWidth": "max-w-(--content-width)",
          "mx": "mx-auto",
          "alignItems": "items-stretch"
        },
        "desktop": {
          "flexDirection": "flex-row",
          "alignItems": "items-center",
          "justifyContent": "justify-between",
          "gap": "gap-8"
        },
        "custom": {
          "displayName": "Strip inner"
        }
      },
      "children": [
        {
          "type": "Container",
          "props": {
            "canDelete": true,
            "canEditName": true,
            "root": {},
            "mobile": {
              "display": "flex",
              "flexDirection": "flex-col",
              "gap": "gap-1",
              "width": "w-full",
              "minWidth": "min-w-0"
            },
            "desktop": {
              "flex": "flex-none",
              "maxWidth": "max-w-sm"
            },
            "custom": {
              "displayName": "Copy column"
            }
          },
          "children": [
            {
              "type": "Text",
              "props": {
                "text": "Product updates in your inbox",
                "tagName": "p",
                "root": {
                  "fontWeight": "font-semibold",
                  "color": "text-(--foreground)"
                },
                "mobile": {
                  "fontSize": "text-sm"
                },
                "desktop": {
                  "fontSize": "text-base"
                },
                "custom": {
                  "displayName": "Strip headline"
                }
              }
            },
            {
              "type": "Text",
              "props": {
                "text": "One email a month. Unsubscribe anytime; we never sell addresses.",
                "tagName": "p",
                "root": {
                  "color": "text-(--muted-foreground)"
                },
                "mobile": {
                  "fontSize": "text-xs",
                  "lineHeight": "leading-relaxed"
                },
                "desktop": {
                  "fontSize": "text-sm"
                },
                "custom": {
                  "displayName": "Strip subline"
                }
              }
            }
          ]
        },
        {
          "type": "Form",
          "props": {
            "canDelete": true,
            "canEditName": true,
            "formName": "newsletter-footer-strip",
            "formType": "subscribe",
            "root": {},
            "mobile": {
              "display": "flex",
              "flexDirection": "flex-col",
              "width": "w-full",
              "minWidth": "min-w-0"
            },
            "desktop": {
              "flex": "flex-1",
              "maxWidth": "max-w-md",
              "minWidth": "min-w-0"
            },
            "custom": {
              "displayName": "Inline subscribe form"
            }
          },
          "children": [
            {
              "type": "Container",
              "props": {
                "canDelete": true,
                "canEditName": true,
                "root": {
                  "background": "bg-(--background)",
                  "border": "border",
                  "borderColor": "border-(--border)",
                  "radius": "rounded-(--radius)"
                },
                "mobile": {
                  "display": "flex",
                  "flexDirection": "flex-row",
                  "alignItems": "items-stretch",
                  "width": "w-full",
                  "overflow": "overflow-hidden"
                },
                "desktop": {},
                "custom": {
                  "displayName": "Email + submit shell"
                }
              },
              "children": [
                {
                  "type": "FormElement",
                  "props": {
                    "type": "email",
                    "name": "email",
                    "label": "",
                    "placeholder": "you@company.com",
                    "required": true,
                    "autocomplete": "email",
                    "root": {
                      "border": "border-0",
                      "radius": "rounded-none",
                      "background": "bg-transparent",
                      "color": "text-(--input-text-color)",
                      "placeholderColor": "placeholder:text-(--input-placeholder-color)",
                      "focus": {
                        "ring": "focus:ring-0",
                        "outline": "focus:outline-none"
                      }
                    },
                    "mobile": {
                      "p": "px-3",
                      "py": "py-2.5",
                      "width": "w-full",
                      "flex": "flex-1",
                      "minWidth": "min-w-0",
                      "fontSize": "text-sm"
                    },
                    "desktop": {},
                    "canDelete": true,
                    "canEditName": true,
                    "custom": {
                      "displayName": "Email"
                    }
                  }
                },
                {
                  "type": "Button",
                  "props": {
                    "text": "Subscribe",
                    "type": "submit",
                    "root": {
                      "background": "bg-(--primary)",
                      "color": "text-(--primary-foreground)",
                      "radius": "rounded-none",
                      "border": "border-0"
                    },
                    "mobile": {
                      "display": "inline-flex",
                      "alignItems": "items-center",
                      "justifyContent": "justify-center",
                      "shrink": "shrink-0",
                      "px": "px-4",
                      "py": "py-2.5",
                      "fontSize": "text-sm",
                      "fontWeight": "font-semibold",
                      "border": "border-l",
                      "borderColor": "border-(--border)"
                    },
                    "desktop": {},
                    "custom": {
                      "displayName": "Submit"
                    }
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
