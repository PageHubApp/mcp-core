{
  "type": "Container",
  "props": {
    "canDelete": true,
    "canEditName": true,
    "type": "section",
    "custom": {
      "displayName": "Newsletter Section"
    },
    "className": "bg-(--background) text-(--foreground) flex flex-col w-full py-(--space-lg) px-(--container-padding-x)"
  },
  "children": [
    {
      "type": "Container",
      "props": {
        "canDelete": true,
        "canEditName": true,
        "custom": {
          "displayName": "Content"
        },
        "className": "max-w-2xl w-full flex flex-col items-center gap-(--space-md) mx-auto"
      },
      "children": [
        {
          "type": "Container",
          "props": {
            "canDelete": true,
            "canEditName": true,
            "custom": {
              "displayName": "Intro"
            },
            "className": "text-center w-full flex flex-col gap-(--space-sm)"
          },
          "children": [
            {
              "type": "Text",
              "props": {
                "text": "Field notes in your inbox",
                "tagName": "h2",
                "custom": {
                  "displayName": "Heading"
                },
                "className": "font-bold text-2xl w-full leading-tight md:text-3xl font-(--heading-font-family)"
              }
            },
            {
              "type": "Text",
              "props": {
                "text": "Occasional emails when we publish something useful, ship a meaningful change, or open early access. Unsubscribe anytime; we never sell addresses.",
                "tagName": "p",
                "custom": {
                  "displayName": "Subhead"
                },
                "className": "text-(--muted-foreground) text-base leading-relaxed w-full max-w-xl mx-auto md:text-lg"
              }
            }
          ]
        },
        {
          "type": "Form",
          "props": {
            "canDelete": true,
            "canEditName": true,
            "formName": "newsletter",
            "formType": "subscribe",
            "custom": {
              "displayName": "Subscribe form"
            },
            "className": "w-full flex flex-col gap-(--space-sm)"
          },
          "children": [
            {
              "type": "Container",
              "props": {
                "canDelete": true,
                "canEditName": true,
                "custom": {
                  "displayName": "Email + button row"
                },
                "className": "bg-(--input-bg-color) border border-(--input-border-color) rounded-(--radius) flex flex-row items-stretch w-full overflow-hidden"
              },
              "children": [
                {
                  "type": "Button",
                  "props": {
                    "type": "button",
                    "text": "Email",
                    "icon": {
                      "value": "ref-google:mail",
                      "only": true,
                      "size": "w-5 h-5"
                    },
                    "custom": {
                      "displayName": "Mail icon"
                    },
                    "className": "bg-transparent text-(--muted-foreground) flex items-center justify-center px-(--container-padding-x) py-(--space-xs) w-auto min-w-0 shrink-0"
                  }
                },
                {
                  "type": "FormElement",
                  "props": {
                    "type": "email",
                    "name": "email",
                    "label": "",
                    "placeholder": "name@email.com",
                    "required": true,
                    "autocomplete": "email",
                    "root": {
                      "style": "placeholder-color: placeholder:text-(--input-placeholder-color);"
                    },
                    "custom": {
                      "displayName": "Email"
                    },
                    "className": "border-0 rounded-none bg-transparent text-(--input-text-color) py-(--space-xs) px-(--container-padding-x) w-full flex-1 min-w-0"
                  }
                },
                {
                  "type": "Button",
                  "props": {
                    "type": "submit",
                    "text": "Get the emails",
                    "custom": {
                      "displayName": "Get the emails"
                    },
                    "className": "bg-(--primary) text-(--primary-foreground) rounded-none shrink-0 px-(--container-padding-x) py-(--space-xs) font-semibold text-sm text-center flex justify-center items-center border-l border-(--input-border-color)"
                  }
                }
              ]
            },
            {
              "type": "Container",
              "props": {
                "canDelete": true,
                "canEditName": true,
                "custom": {
                  "displayName": "Privacy note"
                },
                "className": "w-full flex row flex-wrap items-baseline gap-x-1"
              },
              "children": [
                {
                  "type": "Text",
                  "props": {
                    "text": "Your address stays on this list only.",
                    "tagName": "span",
                    "custom": {
                      "displayName": "Privacy lead"
                    },
                    "className": "text-(--muted-foreground) text-sm leading-relaxed"
                  }
                },
                {
                  "type": "Button",
                  "props": {
                    "text": "Full privacy statement",
                    "url": "/privacy",
                    "custom": {
                      "displayName": "Privacy link"
                    },
                    "className": "bg-transparent text-(--primary) p-(--space-xs) py-(--space-xs) px-(--container-padding-x) w-auto min-w-0 text-sm font-semibold inline-flex"
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
