{
  "type": "Container",
  "props": {
    "canDelete": true,
    "canEditName": true,
    "type": "section",
    "custom": {
      "displayName": "Heading and email form"
    },
    "className": "bg-(--background) text-(--foreground) flex flex-col items-center justify-center w-full py-12 px-4 md:py-16 md:px-6"
  },
  "children": [
    {
      "type": "Container",
      "props": {
        "canDelete": true,
        "canEditName": true,
        "hidden": false,
        "custom": {
          "displayName": "Inner"
        },
        "className": "py-3 px-3 mx-auto flex justify-center flex-col w-full gap-6 max-w-(--content-width) md:max-w-3xl"
      },
      "children": [
        {
          "type": "Container",
          "props": {
            "canDelete": true,
            "canEditName": true,
            "custom": {
              "displayName": "Copy and form"
            },
            "className": "flex justify-center flex-col w-full gap-4 items-stretch md:items-center md:gap-6 md:px-4"
          },
          "children": [
            {
              "type": "Text",
              "props": {
                "canDelete": true,
                "canEditName": true,
                "text": "Get the changelog, not the spam",
                "tagName": "h2",
                "root": {
                  "style": "font-family: var(--heading-font-family);"
                },
                "custom": {
                  "displayName": "Heading"
                },
                "className": "h4 font-bold leading-tight text-(--foreground) text-2xl text-center md:text-4xl md:text-center"
              }
            },
            {
              "type": "Text",
              "props": {
                "canDelete": true,
                "canEditName": true,
                "text": "Drop your work email for release notes, template drops, and builder tips. PageHub does not sell the list.",
                "tagName": "p",
                "custom": {
                  "displayName": "Body"
                },
                "className": "text-(--muted-foreground) leading-relaxed text-base text-center md:text-xl md:text-center md:leading-snug"
              }
            },
            {
              "type": "Form",
              "props": {
                "canDelete": true,
                "canEditName": true,
                "formName": "centered-heading-capture",
                "formType": "subscribe",
                "custom": {
                  "displayName": "Subscribe form"
                },
                "className": "w-full flex flex-col min-w-0 mt-2 md:max-w-md md:min-w-0 md:mx-auto md:w-full"
              },
              "children": [
                {
                  "type": "Container",
                  "props": {
                    "canDelete": true,
                    "canEditName": true,
                    "custom": {
                      "displayName": "Email row"
                    },
                    "className": "bg-(--background) border border-(--border) rounded-(--radius) flex flex-row items-stretch w-full overflow-hidden"
                  },
                  "children": [
                    {
                      "type": "FormElement",
                      "props": {
                        "type": "email",
                        "name": "email",
                        "label": "",
                        "placeholder": "you@company.com",
                        "required": true,
                        "autocomplete": "email",
                        "root": {
                          "style": "placeholder-color: placeholder:text-(--input-placeholder-color);"
                        },
                        "canDelete": true,
                        "canEditName": true,
                        "custom": {
                          "displayName": "Email"
                        },
                        "className": "border-0 rounded-none bg-transparent text-(--input-text-color) px-3 py-2.5 w-full flex-1 min-w-0 text-sm"
                      }
                    },
                    {
                      "type": "Button",
                      "props": {
                        "text": "Subscribe",
                        "type": "submit",
                        "custom": {
                          "displayName": "Submit"
                        },
                        "className": "bg-(--primary) text-(--primary-foreground) rounded-none border-0 inline-flex items-center justify-center shrink-0 px-4 py-2.5 text-sm font-semibold border-l border-(--border)"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
