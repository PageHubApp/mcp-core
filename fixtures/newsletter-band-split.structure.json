{
  "type": "Container",
  "props": {
    "canDelete": true,
    "canEditName": true,
    "type": "section",
    "custom": {
      "displayName": "Newsletter band section"
    },
    "className": "bg-(--background) flex flex-col w-full max-w-none py-12 px-4 md:py-16 md:px-6"
  },
  "children": [
    {
      "type": "Container",
      "props": {
        "canDelete": true,
        "canEditName": true,
        "custom": {
          "displayName": "Newsletter band"
        },
        "className": "bg-(--foreground) text-(--background) rounded-(--card-radius) flex flex-col gap-8 p-8 w-full max-w-(--content-width) mx-auto md:flex-row md:items-center md:justify-between md:gap-12 md:p-10"
      },
      "children": [
        {
          "type": "Container",
          "props": {
            "canDelete": true,
            "canEditName": true,
            "custom": {
              "displayName": "Copy"
            },
            "className": "w-full flex flex-col gap-3 text-center items-center md:flex-1 md:text-left md:items-start md:max-w-lg"
          },
          "children": [
            {
              "type": "Text",
              "props": {
                "text": "Briefings, not blasts",
                "tagName": "h2",
                "custom": {
                  "displayName": "Heading"
                },
                "className": "font-bold text-2xl w-full leading-tight md:text-3xl font-(--heading-font-family)"
              }
            },
            {
              "type": "Text",
              "props": {
                "text": "One note when we have something worth sending—release digests, early access, and no inbox clutter.",
                "tagName": "p",
                "custom": {
                  "displayName": "Subhead"
                },
                "className": "text-(--background) text-sm leading-relaxed w-full opacity-80 md:text-base md:opacity-80"
              }
            }
          ]
        },
        {
          "type": "Container",
          "props": {
            "canDelete": true,
            "canEditName": true,
            "custom": {
              "displayName": "Form column"
            },
            "className": "w-full flex flex-col md:flex-1 md:max-w-md"
          },
          "children": [
            {
              "type": "Form",
              "props": {
                "canDelete": true,
                "canEditName": true,
                "formName": "newsletter-band",
                "formType": "subscribe",
                "custom": {
                  "displayName": "Subscribe form"
                },
                "className": "w-full flex flex-col gap-4"
              },
              "children": [
                {
                  "type": "Container",
                  "props": {
                    "canDelete": true,
                    "canEditName": true,
                    "custom": {
                      "displayName": "Email + button row"
                    },
                    "className": "bg-(--input-bg-color) border border-(--input-border-color) rounded-(--radius) flex flex-row items-stretch w-full overflow-hidden"
                  },
                  "children": [
                    {
                      "type": "Button",
                      "props": {
                        "type": "button",
                        "text": "Email",
                        "icon": {
                          "value": "ref-google:mail",
                          "only": true,
                          "size": "w-5 h-5"
                        },
                        "custom": {
                          "displayName": "Mail icon"
                        },
                        "className": "bg-transparent text-(--muted-foreground) flex items-center justify-center px-3 py-0 w-auto min-w-0 shrink-0"
                      }
                    },
                    {
                      "type": "FormElement",
                      "props": {
                        "type": "email",
                        "name": "email",
                        "label": "",
                        "placeholder": "Work email",
                        "required": true,
                        "autocomplete": "email",
                        "root": {
                          "style": "placeholder-color: placeholder:text-(--input-placeholder-color);"
                        },
                        "custom": {
                          "displayName": "Email"
                        },
                        "className": "border-0 rounded-none bg-transparent text-(--input-text-color) py-3 px-0 w-full flex-1 min-w-0"
                      }
                    },
                    {
                      "type": "Button",
                      "props": {
                        "type": "submit",
                        "text": "Sign me up",
                        "custom": {
                          "displayName": "Sign me up"
                        },
                        "className": "bg-(--primary) text-(--primary-foreground) rounded-none shrink-0 px-5 py-3 font-semibold text-sm text-center flex justify-center items-center border-l border-(--input-border-color)"
                      }
                    }
                  ]
                },
                {
                  "type": "Container",
                  "props": {
                    "canDelete": true,
                    "canEditName": true,
                    "custom": {
                      "displayName": "Privacy note"
                    },
                    "className": "w-full flex row flex-wrap items-baseline gap-x-1 justify-center md:justify-start"
                  },
                  "children": [
                    {
                      "type": "Text",
                      "props": {
                        "text": "This list stays in-house.",
                        "tagName": "span",
                        "custom": {
                          "displayName": "Privacy lead"
                        },
                        "className": "text-(--background) text-sm leading-relaxed opacity-75 md:opacity-75"
                      }
                    },
                    {
                      "type": "Button",
                      "props": {
                        "text": "Data & privacy",
                        "url": "/privacy",
                        "custom": {
                          "displayName": "Privacy link"
                        },
                        "className": "bg-transparent text-(--primary) p-0 py-0 px-0 w-auto min-w-0 text-sm font-semibold inline-flex underline"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
